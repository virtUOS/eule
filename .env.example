# Copy to .env and fill in. Secrets are referenced by NAME in config/*.yaml (the *_env
# fields) and their VALUES live here — never commit real values (golden rule 6).

# --- model provider API keys (referenced by config/global.yaml model_providers.*_env) ---
VLLM_API_KEY=changeme
VLLM_SMALL_API_KEY=changeme
# askUOS static API key (one of the askUOS service's API_KEYS entries) — BUILD_PLAN 9a
ASKUOS_API_KEY=changeme

# --- MCP server bearer tokens (mcp_servers.*.bearer_token_env) ---
UOS_DOCS_MCP_TOKEN=changeme

# --- Caddy site address ---
# ":80" = local plain HTTP. For production set a hostname so Caddy auto-provisions TLS,
# e.g. SITE_ADDRESS=assistant.uni-osnabrueck.de
SITE_ADDRESS=:80

# --- Image tag for the ghcr.io/virtuos/eule/{gateway,widget} images ---
# "latest" tracks main; pin a release (e.g. 1.2) for production. Local source builds
# via `docker compose up --build` ignore the registry either way.
EULE_IMAGE_TAG=latest

# NOTE: the URLs of your EXTERNAL services (vLLM base_url, MCP server urls, Keycloak
# issuer/jwks_url) are set in config/global.yaml, not here — see docs/07-deployment.md.
